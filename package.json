{
  "name": "erp-core-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "ERP Core Prototype (Order-to-Cash) for a cosmetics factory - modular monolith (Express + Prisma/MySQL backend, React/Vite frontend)",
  "workspaces": [
    "src/frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "tsx watch src/backend/server.ts",
    "dev:frontend": "npm run dev --workspace src/frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "prisma generate && tsc -p tsconfig.backend.json",
    "build:frontend": "npm run build --workspace src/frontend",
    "start": "node dist/backend/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test": "jest --runInBand",
    "test:unit": "jest --selectProjects unit --runInBand",
    "test:integration": "cross-env RUN_DB_TESTS=1 jest --selectProjects integration --runInBand",
    "test:e2e": "playwright test",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@playwright/test": "^1.45.3",
    "@types/supertest": "^6.0.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
