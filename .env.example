# Copy this file to .env and adjust values for your environment.
# DevOps owns the final values for each environment (local/staging/prod) - Engineer only defines
# the contract (variable names + safe local defaults for prototype demo). No secret is hardcoded
# in source; everything is read from process.env via src/backend/config.

# --- Database (ADR-003) ---
DATABASE_URL="mysql://erp:erp@localhost:3306/erp_core_prototype"

# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# --- Auth / RBAC (ADR-005 rev.2) ---
JWT_SECRET="change-me-in-real-env"
# Session (login) lifetime, hours-based value expressed in seconds. Default 8h.
SESSION_TTL=28800
# Permission cache TTL in seconds. Default 60s, hard-clamped to <=300s (5 min) by the config loader.
PERMISSION_CACHE_TTL=60

# --- VAT (ECP-038) ---
# Only used by prisma/seed.ts to seed the initial VATConfig row. Runtime rate always comes from DB.
VAT_DEFAULT_RATE=7.00

# --- Invoice editing policy (§5.5) ---
# allow = can revise an invoice chain even if it already has payments (BA default)
# block = revising is blocked once the latest version has any payment recorded
INVOICE_EDIT_AFTER_PAYMENT=allow

# --- Realtime (ADR-004) ---
SOCKET_PATH="/rt"
STOCK_POLL_FALLBACK_MS=30000
