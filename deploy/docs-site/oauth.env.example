# Template for deploy/docs-site/oauth.env  (the real file is .gitignored — NEVER commit it).
# Copy to oauth.env and fill with the values from the Google OAuth 2.0 Client
# (type: Web application) created in Google Auth Platform -> Clients.
#
#   cp deploy/docs-site/oauth.env.example deploy/docs-site/oauth.env
#   # then edit oauth.env
#
# deploy.sh sources this file and passes the values to Cloud Run as env vars.
# The cookie secret is generated fresh by deploy.sh — do NOT put it here.

OAUTH2_PROXY_CLIENT_ID=REPLACE_WITH_OAUTH_CLIENT_ID.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=REPLACE_WITH_OAUTH_CLIENT_SECRET
