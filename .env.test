# DevOps (D2/D3): env for `npm run test:integration` (RUN_DB_TESTS=1 jest --selectProjects
# integration`). Loaded via dotenv-cli (`dotenv -e .env.test -- ...`) so integration/concurrency
# specs never touch the same schema an operator is browsing manually on :5173/:4000.
#
# No real secret in this file (local-only dummy values, same convention as .env.example) -
# safe to commit so the test environment is 100% reproducible for the next person/Phase 3.

# --- Database: dedicated schema, isolated from the dev DB (see docker/mysql/init/) ---
# `?connection_limit=1` = temporary workaround for DEF-06 (NumberSequence first-insert
# LAST_INSERT_ID() bug, see .env for full explanation + docs/test-plans/erp-core-prototype/
# defects.md). NOTE: this also means the concurrency specs under tests/integration/concurrency/
# no longer exercise genuine multi-connection races - they can only validate "no crash / no
# duplicate ID" at low load, NOT that MySQL row-locking correctly serializes real concurrent
# connections. Remove once Engineer's fix lands, then re-run Q7 with real parallelism.
DATABASE_URL="mysql://erp:erp@localhost:3306/erp_core_prototype_test?connection_limit=1"

# --- Server (unused by supertest in-process app, kept for parity with .env.example) ---
PORT=4000
NODE_ENV=test
CORS_ORIGIN="http://localhost:5173"

# --- Auth / RBAC ---
JWT_SECRET="test-secret-not-a-real-secret"
SESSION_TTL=28800
# QA test-plan.md §7 asks for a short TTL so the permission-TTL concurrency spec
# (tests/integration/concurrency/permissionTtl.spec.ts) doesn't need to sleep minutes.
# Still passes through the same clamp (<=300s) as production config.
PERMISSION_CACHE_TTL=2

# --- VAT (ECP-038) ---
VAT_DEFAULT_RATE=7.00

# --- Invoice editing policy (§5.5) ---
INVOICE_EDIT_AFTER_PAYMENT=allow

# --- Realtime (ADR-004) ---
SOCKET_PATH="/rt"
STOCK_POLL_FALLBACK_MS=30000
