// Prisma schema - erp-core-prototype (E1)
// Reference: docs/design/erp-core-prototype/architecture.md §3, ADR-003, ADR-004, ADR-006 rev.2, ADR-007

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum CustomerStatus {
  Active
  Inactive
}

enum ProductStatus {
  Active
  Inactive
}

enum BOMStatus {
  Active
  Inactive
}

enum RawMaterialStatus {
  Active
  Inactive
}

enum IncomingQcStatus {
  Pending
  Passed
  Failed
}

enum StockTxnType {
  Receipt
  Reservation
  ReservationRelease
  Issue
  Adjustment
}

enum POStatus {
  Draft
  Confirmed
  InProduction
  Shipped
  Invoiced
  Closed
  Cancelled
}

enum ProductionOrderStatus {
  Pending
  Assigned
  InProgress
  Completed
  Cancelled
}

enum BatchStatus {
  InProgress
  Completed
  QCPending
  QCApproved
  QCRejected
  ReadyToShip
  Shipped
}

enum QCResult {
  Approved
  Rejected
}

enum ShipmentStatus {
  Draft
  Shipped
  Delivered
}

enum InvoiceStatus {
  Issued
  PartiallyPaid
  Paid
  Superseded
}

enum UserStatus {
  Active
  Inactive
}

// ---------------------------------------------------------------------------
// NumberSequence (ADR-006 rev.2)
// ---------------------------------------------------------------------------

model NumberSequence {
  prefix    String
  periodKey String  @map("period_key")
  counter   BigInt  @default(0)

  @@id([prefix, periodKey])
  @@map("number_sequence")
}

// ---------------------------------------------------------------------------
// RBAC (ADR-005 rev.2)
// ---------------------------------------------------------------------------

model Role {
  id          Int          @id @default(autoincrement())
  roleName    String       @unique @map("role_name")
  isSystem    Boolean      @default(false) @map("is_system")
  permissions Permission[]
  users       User[]

  @@map("role")
}

model Permission {
  id       Int     @id @default(autoincrement())
  roleId   Int     @map("role_id")
  resource String
  action   String
  allow    Boolean @default(true)

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, resource, action])
  @@map("permission")
}

model User {
  id           Int        @id @default(autoincrement())
  userId       String     @unique @map("user_id")
  username     String     @unique
  fullName     String     @map("full_name")
  passwordHash String     @map("password_hash")
  roleId       Int        @map("role_id")
  status       UserStatus @default(Active)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  role                Role              @relation(fields: [roleId], references: [id])
  auditLogs           AuditLog[]
  productionAssigned  ProductionOrder[] @relation("AssignedTo")
  qcInspections       QCInspection[]
  invoicesIssued      Invoice[]         @relation("IssuedBy")
  paymentsRecorded    Payment[]         @relation("RecordedBy")
  vatConfigUpdates    VATConfig[]       @relation("VatUpdatedBy")

  @@index([userId])
  @@map("user")
}

// ---------------------------------------------------------------------------
// Customer (ECP-001..003)
// ---------------------------------------------------------------------------

model Customer {
  id             Int            @id @default(autoincrement())
  customerId     String         @unique @map("customer_id")
  name           String
  address        String?        @db.Text
  phone          String?
  email          String?
  contactPerson  String?        @map("contact_person")
  status         CustomerStatus @default(Active)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  purchaseOrders PurchaseOrder[]

  @@index([customerId])
  @@map("customer")
}

// ---------------------------------------------------------------------------
// Product / RawMaterial / BOM (ECP-007..010)
// ---------------------------------------------------------------------------

model Product {
  id        Int           @id @default(autoincrement())
  name      String
  uom       String
  status    ProductStatus @default(Active)
  createdAt DateTime      @default(now()) @map("created_at")

  bom      BOM?
  poLines  POLine[]
  batches  Batch[]

  @@map("product")
}

model BOM {
  id        Int       @id @default(autoincrement())
  productId Int       @unique @map("product_id")
  status    BOMStatus @default(Active)

  product Product   @relation(fields: [productId], references: [id])
  lines   BOMLine[]

  @@map("bom")
}

model BOMLine {
  id         Int    @id @default(autoincrement())
  bomId      Int    @map("bom_id")
  materialId Int    @map("material_id")
  qtyPerUnit Decimal @map("qty_per_unit") @db.Decimal(12, 4)

  bom      BOM          @relation(fields: [bomId], references: [id])
  material RawMaterial  @relation(fields: [materialId], references: [id])

  @@map("bom_line")
}

model RawMaterial {
  id        Int                @id @default(autoincrement())
  name      String
  uom       String
  status    RawMaterialStatus  @default(Active)
  createdAt DateTime           @default(now()) @map("created_at")

  bomLines          BOMLine[]
  lots              Lot[]
  stockBalance      StockBalance?
  stockTransactions StockTransaction[]
  batchLotUsages    BatchLotUsage[]

  @@map("raw_material")
}

model Lot {
  id               Int              @id @default(autoincrement())
  materialId       Int              @map("material_id")
  lotNumber        String           @map("lot_number")
  receivedQty      Decimal          @map("received_qty") @db.Decimal(12, 3)
  remainingQty     Decimal          @map("remaining_qty") @db.Decimal(12, 3)
  receivedDate     DateTime         @map("received_date")
  incomingQcStatus IncomingQcStatus @default(Pending) @map("incoming_qc_status")
  createdAt        DateTime         @default(now()) @map("created_at")

  material          RawMaterial        @relation(fields: [materialId], references: [id])
  stockTransactions  StockTransaction[]
  batchLotUsages     BatchLotUsage[]

  @@unique([materialId, lotNumber])
  @@map("lot")
}

// ---------------------------------------------------------------------------
// Stock (E8, ADR-004, NFR N1/N3)
// ---------------------------------------------------------------------------

model StockBalance {
  materialId  Int      @id @map("material_id")
  physicalQty Decimal  @default(0) @map("physical_qty") @db.Decimal(12, 3)
  reservedQty Decimal  @default(0) @map("reserved_qty") @db.Decimal(12, 3)
  updatedAt   DateTime @updatedAt @map("updated_at")

  material RawMaterial @relation(fields: [materialId], references: [id])

  @@map("stock_balance")
}

model StockTransaction {
  id         Int          @id @default(autoincrement())
  materialId Int          @map("material_id")
  lotId      Int?         @map("lot_id")
  type       StockTxnType
  qty        Decimal      @db.Decimal(12, 3)
  refDocType String?      @map("ref_doc_type")
  refDocId   Int?         @map("ref_doc_id")
  createdAt  DateTime     @default(now()) @map("created_at")

  material RawMaterial @relation(fields: [materialId], references: [id])
  lot      Lot?        @relation(fields: [lotId], references: [id])

  @@index([materialId, createdAt])
  @@map("stock_transaction")
}

// ---------------------------------------------------------------------------
// Purchase Order (E10, ECP-004..006)
// ---------------------------------------------------------------------------

model PurchaseOrder {
  id                      Int      @id @default(autoincrement())
  poNumber                String   @unique @map("po_number")
  customerId              Int      @map("customer_id")
  orderDate               DateTime @default(now()) @map("order_date")
  requestedDeliveryDate   DateTime @map("requested_delivery_date")
  status                  POStatus @default(Draft)
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  customer          Customer          @relation(fields: [customerId], references: [id])
  lines             POLine[]
  productionOrders  ProductionOrder[]
  shipments         Shipment[]
  invoices          Invoice[]
  statusEvents      POStatusEvent[]

  @@index([status])
  @@index([customerId])
  @@map("purchase_order")
}

// Lightweight append-only timeline used by ECP-006 (5-step timeline with timestamps)
model POStatusEvent {
  id        Int      @id @default(autoincrement())
  poId      Int      @map("po_id")
  status    String
  detail    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  po PurchaseOrder @relation(fields: [poId], references: [id])

  @@index([poId, createdAt])
  @@map("po_status_event")
}

model POLine {
  id        Int     @id @default(autoincrement())
  poId      Int     @map("po_id")
  productId Int     @map("product_id")
  quantity  Decimal @db.Decimal(12, 3)
  uom       String
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)

  po                PurchaseOrder     @relation(fields: [poId], references: [id])
  product           Product           @relation(fields: [productId], references: [id])
  productionOrders  ProductionOrder[]

  @@map("po_line")
}

// ---------------------------------------------------------------------------
// Production / Batch / Traceability (E11/E12)
// ---------------------------------------------------------------------------

model ProductionOrder {
  id         Int                   @id @default(autoincrement())
  poLineId   Int                   @map("po_line_id")
  poId       Int                   @map("po_id")
  assignedTo Int?                  @map("assigned_to")
  status     ProductionOrderStatus @default(Pending)
  plannedQty Decimal               @map("planned_qty") @db.Decimal(12, 3)
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")

  poLine   POLine        @relation(fields: [poLineId], references: [id])
  po       PurchaseOrder @relation(fields: [poId], references: [id])
  assignee User?         @relation("AssignedTo", fields: [assignedTo], references: [id])
  batch    Batch?

  @@index([status])
  @@map("production_order")
}

model Batch {
  id                 Int         @id @default(autoincrement())
  batchNumber        String      @unique @map("batch_number")
  productionOrderId  Int         @unique @map("production_order_id")
  productId          Int         @map("product_id")
  producedQty        Decimal     @map("produced_qty") @db.Decimal(12, 3)
  status             BatchStatus @default(InProgress)
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  productionOrder ProductionOrder  @relation(fields: [productionOrderId], references: [id])
  product         Product          @relation(fields: [productId], references: [id])
  lotUsages       BatchLotUsage[]
  qcInspections   QCInspection[]
  shipments       Shipment[]

  @@index([status])
  @@map("batch")
}

model BatchLotUsage {
  id         Int     @id @default(autoincrement())
  batchId    Int     @map("batch_id")
  lotId      Int     @map("lot_id")
  materialId Int     @map("material_id")
  qtyUsed    Decimal @map("qty_used") @db.Decimal(12, 3)

  batch    Batch       @relation(fields: [batchId], references: [id])
  lot      Lot         @relation(fields: [lotId], references: [id])
  material RawMaterial @relation(fields: [materialId], references: [id])

  @@index([lotId])
  @@index([batchId])
  @@map("batch_lot_usage")
}

model QCInspection {
  id           Int      @id @default(autoincrement())
  batchId      Int      @map("batch_id")
  inspectorId  Int      @map("inspector_id")
  result       QCResult
  remarks      String?  @db.Text
  inspectedAt  DateTime @default(now()) @map("inspected_at")

  batch     Batch @relation(fields: [batchId], references: [id])
  inspector User  @relation(fields: [inspectorId], references: [id])

  @@index([batchId])
  @@map("qc_inspection")
}

// ---------------------------------------------------------------------------
// Shipping (E14)
// ---------------------------------------------------------------------------

model Shipment {
  id             Int            @id @default(autoincrement())
  shipmentNumber String         @unique @map("shipment_number")
  poId           Int            @map("po_id")
  batchId        Int            @map("batch_id")
  shippedDate    DateTime       @map("shipped_date")
  deliveredDate  DateTime?      @map("delivered_date")
  status         ShipmentStatus @default(Draft)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  po    PurchaseOrder @relation(fields: [poId], references: [id])
  batch Batch         @relation(fields: [batchId], references: [id])

  @@index([poId])
  @@map("shipment")
}

// ---------------------------------------------------------------------------
// Invoice + Payment (E15/E20, ADR-006 rev.2 §2)
// ---------------------------------------------------------------------------

model Invoice {
  id               Int           @id @default(autoincrement())
  invoiceNo        String        @map("invoice_no")
  version          Int           @default(1)
  parentInvoiceId  Int?          @map("parent_invoice_id")
  poId             Int           @map("po_id")
  issueDate        DateTime      @default(now()) @map("issue_date")
  issuedById       Int           @map("issued_by")
  subtotal         Decimal       @db.Decimal(12, 2)
  vatRateApplied   Decimal       @map("vat_rate_applied") @db.Decimal(5, 2)
  vatAmount        Decimal       @map("vat_amount") @db.Decimal(12, 2)
  totalAmount      Decimal       @map("total_amount") @db.Decimal(12, 2)
  status           InvoiceStatus @default(Issued)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  po              PurchaseOrder @relation(fields: [poId], references: [id])
  issuedBy        User          @relation("IssuedBy", fields: [issuedById], references: [id])
  parentInvoice   Invoice?      @relation("InvoiceChain", fields: [parentInvoiceId], references: [id])
  childVersions   Invoice[]     @relation("InvoiceChain")
  lines           InvoiceLine[]

  @@unique([invoiceNo, version])
  @@index([poId, version])
  @@map("invoice")
}

model InvoiceLine {
  id          Int     @id @default(autoincrement())
  invoiceId   Int     @map("invoice_id")
  productId   Int     @map("product_id")
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  lineTotal   Decimal @map("line_total") @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_line")
}

model Payment {
  id               Int      @id @default(autoincrement())
  invoiceChainKey  String   @map("invoice_chain_key")
  amount           Decimal  @db.Decimal(12, 2)
  paymentDate      DateTime @map("payment_date")
  method           String
  recordedById     Int      @map("recorded_by")
  createdAt        DateTime @default(now()) @map("created_at")

  recordedBy User @relation("RecordedBy", fields: [recordedById], references: [id])

  @@index([invoiceChainKey])
  @@map("payment")
}

// ---------------------------------------------------------------------------
// VATConfig (ECP-038) - singleton row
// ---------------------------------------------------------------------------

model VATConfig {
  id          Int      @id @default(autoincrement())
  rate        Decimal  @db.Decimal(5, 2)
  updatedById Int      @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy User @relation("VatUpdatedBy", fields: [updatedById], references: [id])

  @@map("vat_config")
}

// ---------------------------------------------------------------------------
// Audit log (E5, ADR-007) - append only
// ---------------------------------------------------------------------------

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  actionType String   @map("action_type")
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  timestamp  DateTime @default(now())
  detail     String?  @db.Text

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, timestamp])
  @@index([actionType, timestamp])
  @@map("audit_log")
}
