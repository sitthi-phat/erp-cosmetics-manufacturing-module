# Local dev image for the backend (Express + Prisma). DevOps may retune for prod (D-tasks).
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
COPY prisma ./prisma
RUN npm install

COPY . .

RUN npx prisma generate

EXPOSE 4000

CMD ["sh", "-c", "npx prisma migrate deploy && npx tsx watch src/backend/server.ts"]
